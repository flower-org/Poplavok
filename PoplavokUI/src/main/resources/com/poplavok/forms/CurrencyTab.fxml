<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>

<fx:root prefHeight="706.0" prefWidth="997.0" type="AnchorPane" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <SplitPane dividerPositions="0.5" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" orientation="VERTICAL" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
        <AnchorPane maxHeight="40.0" minHeight="40.0" prefHeight="40.0" SplitPane.resizableWithParent="false">
            <ToolBar AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <TextField fx:id="filterTextField" onKeyTyped="#filterTableView" />
                <Button mnemonicParsing="false" onAction="#showCurrencyDetails" text="[ Details ]" />
                <Button mnemonicParsing="false" onAction="#refreshContent" text="[ Refresh (from DB) ]" />
                <Button mnemonicParsing="false" onAction="#retrieveFromExchange" text="[ Retrieve (from exchange) ]" />
                <Button mnemonicParsing="false" onAction="#retrieveExtendedData" text="[ Retrieve extended data ]" />
            </ToolBar>
        </AnchorPane>
        <AnchorPane>
            <TableView fx:id="currenciesTable" onMouseClicked="#mouseClick" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columns>
                    <TableColumn text="CurrencyId">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="FullName">
                        <cellValueFactory>
                            <PropertyValueFactory property="fullName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Currency">
                        <cellValueFactory>
                            <PropertyValueFactory property="currency" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Name">
                        <cellValueFactory>
                            <PropertyValueFactory property="name" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Precision">
                        <cellValueFactory>
                            <PropertyValueFactory property="precision" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="WithdrawalMinSize">
                        <cellValueFactory>
                            <PropertyValueFactory property="withdrawalMinSize" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="WithdrawalMinFee">
                        <cellValueFactory>
                            <PropertyValueFactory property="withdrawalMinFee" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsWithdrawEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isWithdrawEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsDepositEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isDepositEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsMarginEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isMarginEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsDebitEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isDebitEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </AnchorPane>
    </SplitPane>
</fx:root>
