<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<fx:root type="AnchorPane" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <SplitPane dividerPositions="0.0, 0.0, 0.0, 0.5" orientation="VERTICAL" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
        <AnchorPane maxHeight="40.0" minHeight="40.0" prefHeight="40.0" SplitPane.resizableWithParent="false">
            <ToolBar AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <Button mnemonicParsing="false" onAction="#retrieveExtendedData" text="[ Retrieve extended data (from exchange) ]" />
            </ToolBar>
        </AnchorPane>
        <AnchorPane maxHeight="125.0" minHeight="125.0" prefHeight="125.0" SplitPane.resizableWithParent="false">
            <GridPane layoutY="-25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="5.0" prefHeight="5.0" vgrow="SOMETIMES" />
                </rowConstraints>
                <Label text="CurrencyId:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label text="FullName:" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="Currency:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <Label text="Name:" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <TextField fx:id="currencyId" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="fullName" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="currencyText" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="currencyName" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Precision:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label text="WithdrawalMinSize:" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label text="WithdrawalMinFee:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <Label text="IsWithdrawEnabled:" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                <TextField fx:id="precision" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="withdrawalMinSize" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="withdrawalMinFee" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                <TextField fx:id="isWithdrawEnabled" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                <Label text="IsDepositEnabled:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <Label text="IsMarginEnabled:" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Label text="IsDebitEnabled:" GridPane.columnIndex="2" GridPane.rowIndex="4" />

                <TextField fx:id="isDepositEnabled" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="isMarginEnabled" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <TextField fx:id="isDebitEnabled" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="5" />
            </GridPane>
        </AnchorPane>
        <AnchorPane maxHeight="165.0" minHeight="165.0" prefHeight="165.0" SplitPane.resizableWithParent="false">
            <GridPane layoutY="-25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="5.0" prefHeight="5.0" vgrow="SOMETIMES" />
                </rowConstraints>
                <Label text="CurrencyExtendedInfoId:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label text="Code:" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="Symbol:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <Label text="Name:" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <TextField fx:id="currencyExtendedInfoId" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="code" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="symbol" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="currencyExtendedInfoName" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="MarketCap:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label text="CirculatingSupply:" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label text="TotalSupply:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <Label text="MaxSupply:" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                <TextField fx:id="marketCap" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="circulatingSupply" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="totalSupply" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                <TextField fx:id="maxSupply" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                <Label text="Website:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <Label text="Whitepaper:" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Label text="IssueDate:" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                <Label text="IssuePrice:" GridPane.columnIndex="3" GridPane.rowIndex="4" />

                <TextField fx:id="website" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="whitepaper" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <TextField fx:id="issueDate" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="2" GridPane.rowIndex="5" />
                <TextField fx:id="issuePrice" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="5" />

                <Label text="ROI:" GridPane.columnIndex="0" GridPane.rowIndex="6" />

                <TextField fx:id="roi" editable="false" style="-fx-background-color: light-grey;" text="-" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            </GridPane>
        </AnchorPane>
        <AnchorPane minHeight="100">
            <SplitPane dividerPositions="0.5" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <AnchorPane>
                    <TextArea fx:id="explorer" editable="false" style="-fx-background-color: light-grey;" wrapText="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                </AnchorPane>
                <AnchorPane>
                    <TextArea fx:id="introduceText" editable="false" style="-fx-background-color: light-grey;" wrapText="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                </AnchorPane>
            </SplitPane>
        </AnchorPane>
        <AnchorPane minHeight="100">
            <TableView fx:id="currencyChainExTable" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columns>
                    <TableColumn text="CurrencyChainId">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Currency">
                        <cellValueFactory>
                            <PropertyValueFactory property="currency" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Chain">
                        <cellValueFactory>
                            <PropertyValueFactory property="chain" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="WithdrawalMinSize">
                        <cellValueFactory>
                            <PropertyValueFactory property="withdrawalMinSize" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="WithdrawalMinFee">
                        <cellValueFactory>
                            <PropertyValueFactory property="withdrawalMinFee" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsWithdrawEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isWithdrawEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="IsDepositEnabled">
                        <cellValueFactory>
                            <PropertyValueFactory property="isDepositEnabled" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Confirms">
                        <cellValueFactory>
                            <PropertyValueFactory property="confirms" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="ContractAddress">
                        <cellValueFactory>
                            <PropertyValueFactory property="contractAddress" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="CurrencyId">
                        <cellValueFactory>
                            <PropertyValueFactory property="currencyId" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="ChainId">
                        <cellValueFactory>
                            <PropertyValueFactory property="chainId" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </AnchorPane>
    </SplitPane>
</fx:root>
