<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>

<fx:root prefHeight="690.0" prefWidth="823.0" type="AnchorPane" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <SplitPane dividerPositions="0.5" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" orientation="VERTICAL" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
        <AnchorPane maxHeight="40.0" minHeight="40.0" prefHeight="40.0" SplitPane.resizableWithParent="false">
            <ToolBar AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <TextField fx:id="filterTextField" onKeyTyped="#filterTableView" />
                <Button mnemonicParsing="false" text="[ Long ]" onAction="#longCalc"/>
                <Button mnemonicParsing="false" text="[ Short ]" onAction="#shortCalc"/>
                <Button mnemonicParsing="false" onAction="#refreshContent" text="[ Refresh (from DB) ]" />
                <Button mnemonicParsing="false" onAction="#retrieveFromExchange" text="[ Retrieve (from exchange) ]" />
            </ToolBar>
        </AnchorPane>
        <AnchorPane>
            <TableView fx:id="marketTickersTable" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columns>
                    <TableColumn text="MarketTickerId">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Symbol">
                        <cellValueFactory>
                            <PropertyValueFactory property="symbol" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="SymbolName">
                        <cellValueFactory>
                            <PropertyValueFactory property="symbolName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="TakerFeeRate">
                        <cellValueFactory>
                            <PropertyValueFactory property="takerFeeRate" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="MakerFeeRate">
                        <cellValueFactory>
                            <PropertyValueFactory property="makerFeeRate" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="TakerCoefficient">
                        <cellValueFactory>
                            <PropertyValueFactory property="takerCoefficient" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="MakerCoefficient">
                        <cellValueFactory>
                            <PropertyValueFactory property="makerCoefficient" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </AnchorPane>
    </SplitPane>
</fx:root>
